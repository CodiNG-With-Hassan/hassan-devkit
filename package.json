{
  "name": "hassan-devkit",
  "version": "0.0.0",
  "private": true,
  "description": "Shared developer-experience toolkit: ESLint/Prettier/lint-staged configs, a small CLI, and a Renovate preset, used across Hassan's client projects.",
  "license": "MIT",
  "author": "Hassan Khousheish",
  "repository": {
    "type": "git",
    "url": "https://github.com/CodiNG-With-Hassan/hassan-devkit.git"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build --if-present",
    "lint": "pnpm -r --filter \"./packages/**\" run lint --if-present",
    "test": "pnpm -r --filter \"./packages/**\" run test --if-present",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10"
  },
  "engines": {
    "node": ">=20"
  }
}
